# MSUNLI Language Technology Platform - Environment Configuration

# Application
APP_NAME=MSUNLI Language Technology Platform
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database
DATABASE_URL=postgresql://zilp:zilp_secret@localhost:5432/zilp

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7

# Rate Limiting
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=60

# CORS
CORS_ORIGINS=["*"]

# Testing
TEST_MODE=false
